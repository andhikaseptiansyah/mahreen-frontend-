# local: seluruh transaksi memakai browser storage untuk demo/testing.
# api: seluruh transaksi memakai backend dan gagal bila backend tidak tersedia.
# auto: mencoba backend, lalu fallback ke local hanya jika server tidak tersedia.
VITE_DATA_SOURCE=local

VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT_MS=15000
VITE_API_USE_CREDENTIALS=true
VITE_ENABLE_LOCAL_FALLBACK=true
